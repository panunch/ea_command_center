# EA Command Center — Environment Variables
# Copy this file to .env and fill in your values

# ─── AIRTABLE ────────────────────────────────────
# Get your API key: https://airtable.com/account
# Get your base ID: Open your base → Help → API documentation → The base ID is in the URL
AIRTABLE_API_KEY=pat_your_key_here
AIRTABLE_BASE_ID=app_your_base_id_here

# Required Airtable tables:
#   "Tasks"       → Title, Priority, Category, Due, Status
#   "Follow-ups"  → Item, Contact, DueDate
#   "Notes"       → Content, Tags, Timestamp

# ─── TRELLO ──────────────────────────────────────
# Get API key: https://trello.com/power-ups/admin
# Get token: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_KEY
# Get board ID: Open board → add .json to URL → find "id" field
TRELLO_API_KEY=your_trello_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id

# Expected Trello board lists: "To Do", "Doing", "Done"
# Use labels for priority (High/Medium/Low) and category (Executive/HR/Operations/Admin)
